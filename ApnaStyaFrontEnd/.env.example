# Backend API base URL (no trailing slash).
# - Local dev: use your backend URL (e.g. http://localhost:8080)
# - Production: set this in your hosting's environment variables to your production API (e.g. https://api.yourdomain.com)
# The frontend URL (where the app is hosted) does not need to be set here — it is whatever domain users open (e.g. https://yourapp.vercel.app).
VITE_API_BASE_URL=http://localhost:8080
